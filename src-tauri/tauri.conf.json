{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DarkTasks",
  "version": "0.1.0",
  "identifier": "com.darktasks.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run desktop:prepare"
  },
  "app": {
    "windows": [
      {
        "title": "DarkTasks",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "center": true,
        "theme": "Dark",
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/darktasks-api"],
    "resources": {
      "../.env": ".env"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
